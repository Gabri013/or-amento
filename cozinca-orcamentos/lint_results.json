y, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1520,1523],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":72,"column":32,"messageId":"unexpectedAny","endLine":72,"endColumn":35,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1979,1982],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1979,1982],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":4,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { collection, getDocs, getDoc, addDoc, updateDoc, deleteDoc, doc, query, where, QueryConstraint, serverTimestamp } from 'firebase/firestore';\r\nimport { db } from './config';\r\n\r\nexport const COLECOES = {\r\n  USUARIOS: 'usuarios',\r\n  ORCAMENTOS: 'orcamentos',\r\n  CLIENTES: 'clientes',\r\n  PRODUTOS: 'produtos',\r\n  VENDAS: 'vendas',\r\n} as const;\r\n\r\nexport async function buscarColecao<T>(\r\n  colecao: string,\r\n  filtros?: QueryConstraint[]\r\n): Promise<T[]> {\r\n  const ref = collection(db, colecao);\r\n  const q = filtros && filtros.length > 0 ? query(ref, ...filtros) : ref;\r\n  const snapshot = await getDocs(q);\r\n  return snapshot.docs.map((d: any) => ({ ...(d.data() as T), id: d.id }));\r\n}\r\n\r\nexport async function buscarDocumento<T>(\r\n  colecao: string,\r\n  id: string\r\n): Promise<T | null> {\r\n  const docRef = doc(db, colecao, id);\r\n  const snapshot = await getDoc(docRef);\r\n  if (!snapshot.exists()) return null;\r\n  return { ...(snapshot.data() as T), id: snapshot.id };\r\n}\r\n\r\nexport async function salvarDocumento<T>(\r\n  colecao: string,\r\n  dados: Omit<T, 'id'>\r\n): Promise<string> {\r\n  const ref = collection(db, colecao);\r\n  const docRef = await addDoc(ref, {\r\n    ...dados,\r\n    criadoEm: serverTimestamp(),\r\n  } as any);\r\n  return docRef.id;\r\n}\r\n\r\nexport async function atualizarDocumento(\r\n  colecao: string,\r\n  id: string,\r\n  dados: Record<string, unknown>\r\n): Promise<void> {\r\n  const docRef = doc(db, colecao, id);\r\n  await updateDoc(docRef, {\r\n    ...dados,\r\n    atualizadoEm: serverTimestamp(),\r\n  } as any);\r\n}\r\n\r\nexport async function excluirDocumento(\r\n  colecao: string,\r\n  id: string\r\n): Promise<void> {\r\n  const docRef = doc(db, colecao, id);\r\n  await deleteDoc(docRef);\r\n}\r\n\r\nexport async function buscarComFiltro<T>(\r\n  colecao: string,\r\n  campo: string,\r\n  valor: unknown\r\n): Promise<T[]> {\r\n  const ref = collection(db, colecao);\r\n  const q = query(ref, where(campo, '==', valor));\r\n  const snapshot = await getDocs(q);\r\n  return snapshot.docs.map((d: any) => ({ ...(d.data() as T), id: d.id }));\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\GABRIEL\\Documents\\GitHub\\or-amento\\cozinca-orcamentos\\src\\firebase\\seed.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\GABRIEL\\Documents\\GitHub\\or-amento\\cozinca-orcamentos\\src\\main.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\GABRIEL\\Documents\\GitHub\\or-amento\\cozinca-orcamentos\\src\\pages\\Admin.tsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\nC:\\Users\\GABRIEL\\Documents\\GitHub\\or-amento\\cozinca-orcamentos\\src\\pages\\Admin.tsx:25:21\n  23 |   };\n  24 |\n> 25 |   useEffect(() => { carregar(); }, []);\n     |                     ^^^^^^^^ Avoid calling setState() directly within an effect\n  26 |\n  27 |   const handleCriar = async (e: React.FormEvent) => {\n  28 |     e.preventDefault();","line":25,"column":21,"endLine":25,"endColumn":29}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect } from 'react';\r\nimport { httpsCallable } from 'firebase/functions';\r\nimport { getFunctions } from 'firebase/functions';\r\nimport { buscarColecao, atualizarDocumento, COLECOES } from '../firebase/firestore';\r\nimport type { Usuario } from '../types';\r\n\r\nexport default function Admin() {\r\n  const [usuarios, setUsuarios] = useState<Usuario[]>([]);\r\n  const [loading, setLoading] = useState(true);\r\n\r\n  const [novoNome, setNovoNome] = useState('');\r\n  const [novoEmail, setNovoEmail] = useState('');\r\n  const [novaSenha, setNovaSenha] = useState('');\r\n  const [novoTipo, setNovoTipo] = useState<'admin' | 'usuario'>('usuario');\r\n  const [criando, setCriando] = useState(false);\r\n  const [erro, setErro] = useState('');\r\n\r\n  const carregar = async () => {\r\n    try {\r\n      const dados = await buscarColecao<Usuario>(COLECOES.USUARIOS);\r\n      setUsuarios(dados);\r\n    } catch (err) { console.error(err); } finally { setLoading(false); }\r\n  };\r\n\r\n  useEffect(() => { carregar(); }, []);\r\n\r\n  const handleCriar = async (e: React.FormEvent) => {\r\n    e.preventDefault();\r\n    setErro('');\r\n    setCriando(true);\r\n    try {\r\n      const functions = getFunctions();\r\n      const criarUsuario = httpsCallable(functions, 'criarUsuario');\r\n      await criarUsuario({ nome: novoNome, email: novoEmail, senha: novaSenha, tipo: novoTipo });\r\n      setNovoNome(''); setNovoEmail(''); setNovaSenha(''); setNovoTipo('usuario');\r\n      carregar();\r\n    } catch (err) {\r\n      console.error(err);\r\n      setErro('Erro ao criar usu├írio. Verifique se a Cloud Function est├í implantada.');\r\n    } finally { setCriando(false); }\r\n  };\r\n\r\n  const handleToggleAtivo = async (usuario: Usuario) => {\r\n    try { await atualizarDocumento(COLECOES.USUARIOS, usuario.uid, { ativo: !usuario.ativo });\r\n      setUsuarios((prev) => prev.map((u) => (u.uid === usuario.uid ? { ...u, ativo: !u.ativo } : u)));\r\n    } catch (err) { console.error(err); alert('Erro ao atualizar usu├írio.'); }\r\n  };\r\n\r\n  if (loading) { return <div className=\"d-flex justify-content-center align-items-center vh-100\"><div className=\"spinner-border text-primary\" role=\"status\" /></div>; }\r\n\r\n  return (\r\n    <div>\r\n      <div className=\"d-flex justify-content-between align-items-center mb-4\" style={{ borderBottom: '2px solid #ff530d', paddingBottom: '10px' }}>\r\n        <h2 style={{ color: '#ff530d', fontWeight: 700, margin: 0 }}>Gerenciamento de Usu├írios</h2>\r\n        <button className=\"btn btn-outline-secondary btn-sm\" onClick={() => window.history.back()}>ÔåÉ Voltar ao painel</button>\r\n      </div>\r\n      {erro && <div className=\"alert mb-3\" style={{ background: '#f8d7da', color: '#842029', border: '1px solid #f5c2c7', borderRadius: '8px' }}>{erro}</div>}\r\n      <div className=\"card mb-4\" style={{ border: 'none', boxShadow: '0 2px 10px rgba(0,0,0,.06)', borderRadius: '12px' }}>\r\n        <div className=\"card-body\">\r\n          <h5 className=\"card-title mb-3\">Novo Usu├írio</h5>\r\n          <form onSubmit={handleCriar}>\r\n            <div className=\"row g-2\">\r\n              <div className=\"col-md-3\"><input type=\"text\" className=\"form-control\" placeholder=\"Nome\" value={novoNome} onChange={(e) => setNovoNome(e.target.value)} required /></div>\r\n              <div className=\"col-md-3\"><input type=\"email\" className=\"form-control\" placeholder=\"Email\" value={novoEmail} onChange={(e) => setNovoEmail(e.target.value)} required /></div>\r\n              <div className=\"col-md-3\"><input type=\"password\" className=\"form-control\" placeholder=\"Senha\" value={novaSenha} onChange={(e) => setNovaSenha(e.target.value)} required minLength={6} /></div>\r\n              <div className=\"col-md-2\"><select className=\"form-select\" value={novoTipo} onChange={(e) => setNovoTipo(e.target.value as 'admin' | 'usuario')}><option value=\"usuario\">Vendedor</option><option value=\"admin\">Administrador</option></select></div>\r\n              <div className=\"col-md-1\"><button type=\"submit\" className=\"btn w-100\" disabled={criando} style={{ background: '#ff530d', color: '#fff' }}>{criando ? '...' : '+'}</button></div>\r\n            </div>\r\n          </form>\r\n        </div>\r\n      </div>\r\n      <div className=\"card\" style={{ border: 'none', boxShadow: '0 2px 10px rgba(0,0,0,.06)', borderRadius: '12px' }}>\r\n        <div className=\"card-body\">\r\n          <h5 className=\"card-title mb-3\">Usu├írios Cadastrados</h5>\r\n          <div style={{ overflow: 'auto' }}>\r\n            <table className=\"table table-hover mb-0\">\r\n              <thead><tr style={{ background: '#1c1c1c', color: '#fff' }}><th>Nome</th><th>Email</th><th>Tipo</th><th>Status</th><th style={{ textAlign: 'right' }}>A├º├Áes</th></tr></thead>\r\n              <tbody>\r\n                {usuarios.map((u) => (\r\n                  <tr key={u.uid}>\r\n                    <td>{u.nome}</td>\r\n                    <td>{u.email}</td>\r\n                    <td><span className=\"badge\" style={{ background: u.tipo === 'admin' ? '#e3f2fd' : '#f3e5f5', color: u.tipo === 'admin' ? '#1565c0' : '#7b1fa2' }}>{u.tipo.toUpperCase()}</span></td>\r\n                    <td><span className=\"badge\" style={{ background: u.ativo ? '#d1fae5' : '#fee2e2', color: u.ativo ? '#065f46' : '#991b1b' }}>{u.ativo ? 'ATIVO' : 'INATIVO'}</span></td>\r\n                    <td style={{ textAlign: 'right' }}><button className={`btn btn-sm ${u.ativo ? 'btn-outline-danger' : 'btn-outline-success'}`} onClick={() => handleToggleAtivo(u)}>{u.ativo ? 'Desativar' : 'Ativar'}</button></td>\r\n                  </tr>\r\n                ))}\r\n              </tbody>\r\n            </table>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\GABRIEL\\Documents\\GitHub\\or-amento\\cozinca-orcamentos\\src\\pages\\Cadastro.tsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\nC:\\Users\\GABRIEL\\Documents\\GitHub\\or-amento\\cozinca-orcamentos\\src\\pages\\Cadastro.tsx:41:21\n  39 |   };\n  40 |\n> 41 |   useEffect(() => { carregar(); }, []);\n     |                     ^^^^^^^^ Avoid calling setState() directly within an effect\n  42 |\n  43 |   const limparForm = () => { setNome(''); setDocumento(''); setTelefone(''); setEmail(''); setEndereco(''); setEditandoId(null); };\n  44 |   const handleEditar = (cli: Cliente) => { setNome(cli.nome); setDocumento(cli.documento); setTelefone(cli.telefone); setEmail(cli.email); setEndereco(cli.endereco); setEditandoId(cli.id); setMostrarForm(true); };","line":41,"column":21,"endLine":41,"endColumn":29},{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\nC:\\Users\\GABRIEL\\Documents\\GitHub\\or-amento\\cozinca-orcamentos\\src\\pages\\Cadastro.tsx:119:21\n  117 |   };\n  118 |\n> 119 |   useEffect(() => { carregar(); }, []);\n      |                     ^^^^^^^^ Avoid calling setState() directly within an effect\n  120 |\n  121 |   const limparForm = () => { setNome(''); setSku(''); setDescricao(''); setPrecoBase(''); setUnidade('un'); setAtivo(true); setImagem(''); setArquivoImagem(null); setEditandoId(null); };\n  122 |   const handleEditar = (p: Produto) => { setNome(p.nome); setSku(p.sku); setDescricao(p.descricao); setPrecoBase(String(p.precoBase)); setUnidade(p.unidade); setAtivo(p.ativo); setImagem(p.imagem || ''); setEditandoId(p.id); setMostrarForm(true); };","line":119,"column":21,"endLine":119,"endColumn":29}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect } from 'react';\r\nimport { buscarColecao, salvarDocumento, atualizarDocumento, excluirDocumento, COLECOES } from '../firebase/firestore';\r\nimport { getDownloadURL, ref, uploadBytes } from 'firebase/storage';\r\nimport { storage } from '../firebase/config';\r\nimport type { Cliente, Produto } from '../types';\r\n\r\nexport default function Cadastro() {\r\n  const [aba, setAba] = useState<'clientes' | 'produtos'>('clientes');\r\n  return (\r\n    <div>\r\n      <div className=\"d-flex justify-content-between align-items-center mb-4\" style={{ borderBottom: '2px solid #ff530d', paddingBottom: '10px' }}>\r\n        <h2 style={{ color: '#ff530d', fontWeight: 700, margin: 0 }}>Cadastro</h2>\r\n        <div className=\"d-flex gap-2\">\r\n          <button className={`btn btn-sm ${aba === 'clientes' ? '' : 'btn-outline-primary'}`} style={aba === 'clientes' ? { background: '#ff530d', color: '#fff', borderRadius: '8px' } : {}} onClick={() => setAba('clientes')}>Clientes</button>\r\n          <button className={`btn btn-sm ${aba === 'produtos' ? '' : 'btn-outline-primary'}`} style={aba === 'produtos' ? { background: '#ff530d', color: '#fff', borderRadius: '8px' } : {}} onClick={() => setAba('produtos')}>Produtos</button>\r\n        </div>\r\n      </div>\r\n      {aba === 'clientes' ? <ClientesTab /> : <ProdutosTab />}\r\n    </div>\r\n  );\r\n}\r\n\r\nfunction ClientesTab() {\r\n  const [clientes, setClientes] = useState<Cliente[]>([]);\r\n  const [loading, setLoading] = useState(true);\r\n  const [mostrarForm, setMostrarForm] = useState(false);\r\n  const [editandoId, setEditandoId] = useState<string | null>(null);\r\n  const [nome, setNome] = useState('');\r\n  const [documento, setDocumento] = useState('');\r\n  const [telefone, setTelefone] = useState('');\r\n  const [email, setEmail] = useState('');\r\n  const [endereco, setEndereco] = useState('');\r\n\r\n  const carregar = async () => {\r\n    try {\r\n      const dados = await buscarColecao<Cliente>(COLECOES.CLIENTES);\r\n      setClientes(dados);\r\n    } catch (err) { console.error(err); } finally { setLoading(false); }\r\n  };\r\n\r\n  useEffect(() => { carregar(); }, []);\r\n\r\n  const limparForm = () => { setNome(''); setDocumento(''); setTelefone(''); setEmail(''); setEndereco(''); setEditandoId(null); };\r\n  const handleEditar = (cli: Cliente) => { setNome(cli.nome); setDocumento(cli.documento); setTelefone(cli.telefone); setEmail(cli.email); setEndereco(cli.endereco); setEditandoId(cli.id); setMostrarForm(true); };\r\n\r\n  const handleSalvar = async (e: React.FormEvent) => {\r\n    e.preventDefault();\r\n    try {\r\n      if (editandoId) { await atualizarDocumento(COLECOES.CLIENTES, editandoId, { nome, documento, telefone, email, endereco }); }\r\n      else { await salvarDocumento(COLECOES.CLIENTES, { nome, documento, telefone, email, endereco, criadoEm: new Date() }); }\r\n      limparForm(); setMostrarForm(false); carregar();\r\n    } catch (err) { console.error(err); alert('Erro ao salvar cliente.'); }\r\n  };\r\n\r\n  const handleExcluir = async (id: string) => {\r\n    if (!window.confirm('Excluir cliente?')) return;\r\n    try { await excluirDocumento(COLECOES.CLIENTES, id); carregar(); } catch (err) { console.error(err); alert('Erro ao excluir cliente.'); }\r\n  };\r\n\r\n  return (\r\n    <div>\r\n      <div className=\"mb-3\"><button className=\"btn\" style={{ background: '#ff530d', color: '#fff', borderRadius: '8px' }} onClick={() => { limparForm(); setMostrarForm(true); }}>+ Novo Cliente</button></div>\r\n      {mostrarForm && (\r\n        <div className=\"card mb-4\" style={{ border: 'none', boxShadow: '0 2px 10px rgba(0,0,0,.06)', borderRadius: '12px' }}>\r\n          <div className=\"card-body\">\r\n            <h5 className=\"card-title mb-3\">{editandoId ? 'Editar Cliente' : 'Novo Cliente'}</h5>\r\n            <form onSubmit={handleSalvar}>\r\n              <div className=\"row g-3\">\r\n                <div className=\"col-md-4\"><label className=\"form-label\">Nome / Raz├úo Social</label><input type=\"text\" className=\"form-control\" value={nome} onChange={(e) => setNome(e.target.value)} required /></div>\r\n                <div className=\"col-md-4\"><label className=\"form-label\">CNPJ / CPF</label><input type=\"text\" className=\"form-control\" value={documento} onChange={(e) => setDocumento(e.target.value)} /></div>\r\n                <div className=\"col-md-4\"><label className=\"form-label\">Telefone</label><input type=\"text\" className=\"form-control\" value={telefone} onChange={(e) => setTelefone(e.target.value)} /></div>\r\n                <div className=\"col-md-4\"><label className=\"form-label\">Email</label><input type=\"email\" className=\"form-control\" value={email} onChange={(e) => setEmail(e.target.value)} /></div>\r\n                <div className=\"col-md-8\"><label className=\"form-label\">Endere├ºo</label><input type=\"text\" className=\"form-control\" value={endereco} onChange={(e) => setEndereco(e.target.value)} /></div>\r\n                <div className=\"col-12 mt-2\">\r\n                  <button type=\"submit\" className=\"btn\" style={{ background: '#ff530d', color: '#fff' }}>{editandoId ? 'Atualizar' : 'Salvar'}</button>\r\n                  <button type=\"button\" className=\"btn btn-outline-secondary ms-2\" onClick={() => { limparForm(); setMostrarForm(false); }}>Cancelar</button>\r\n                </div>\r\n              </div>\r\n            </form>\r\n          </div>\r\n        </div>\r\n      )}\r\n      {loading ? <div className=\"spinner-border text-primary\" role=\"status\" /> : (\r\n        <div style={{ background: '#fff', borderRadius: '12px', boxShadow: '0 2px 8px rgba(0,0,0,.06)', overflow: 'auto' }}>\r\n          <table className=\"table table-hover mb-0\">\r\n            <thead><tr style={{ background: '#1c1c1c', color: '#fff' }}><th>Nome</th><th>Documento</th><th>Telefone</th><th>Email</th><th>Endere├ºo</th><th style={{ textAlign: 'right' }}>A├º├Áes</th></tr></thead>\r\n            <tbody>\r\n              {clientes.map((cli) => <tr key={cli.id}><td>{cli.nome}</td><td>{cli.documento}</td><td>{cli.telefone}</td><td>{cli.email}</td><td>{cli.endereco}</td><td style={{ textAlign: 'right' }}><div className=\"d-flex justify-content-end gap-1\"><button className=\"btn btn-sm btn-outline-primary\" onClick={() => handleEditar(cli)}>Editar</button><button className=\"btn btn-sm btn-outline-danger\" onClick={() => handleExcluir(cli.id)}>Ô£ò</button></div></td></tr>)}\r\n              {clientes.length === 0 && <tr><td colSpan={6} className=\"text-center py-4 text-muted\">Nenhum cliente cadastrado.</td></tr>}\r\n            </tbody>\r\n          </table>\r\n        </div>\r\n      )}\r\n    </div>\r\n  );\r\n}\r\n\r\nfunction ProdutosTab() {\r\n  const [produtos, setProdutos] = useState<Produto[]>([]);\r\n  const [loading, setLoading] = useState(true);\r\n  const [mostrarForm, setMostrarForm] = useState(false);\r\n  const [editandoId, setEditandoId] = useState<string | null>(null);\r\n  const [nome, setNome] = useState('');\r\n  const [sku, setSku] = useState('');\r\n  const [descricao, setDescricao] = useState('');\r\n  const [precoBase, setPrecoBase] = useState('');\r\n  const [unidade, setUnidade] = useState('un');\r\n  const [ativo, setAtivo] = useState(true);\r\n  const [imagem, setImagem] = useState('');\r\n  const [arquivoImagem, setArquivoImagem] = useState<File | null>(null);\r\n\r\n  const carregar = async () => {\r\n    try {\r\n      const dados = await buscarColecao<Produto>(COLECOES.PRODUTOS);\r\n      setProdutos(dados);\r\n    } catch (err) { console.error(err); } finally { setLoading(false); }\r\n  };\r\n\r\n  useEffect(() => { carregar(); }, []);\r\n\r\n  const limparForm = () => { setNome(''); setSku(''); setDescricao(''); setPrecoBase(''); setUnidade('un'); setAtivo(true); setImagem(''); setArquivoImagem(null); setEditandoId(null); };\r\n  const handleEditar = (p: Produto) => { setNome(p.nome); setSku(p.sku); setDescricao(p.descricao); setPrecoBase(String(p.precoBase)); setUnidade(p.unidade); setAtivo(p.ativo); setImagem(p.imagem || ''); setEditandoId(p.id); setMostrarForm(true); };\r\n\r\n  const handleSalvar = async (e: React.FormEvent) => {\r\n    e.preventDefault();\r\n    try {\r\n      let imagemUrl = imagem;\r\n      if (arquivoImagem) {\r\n        const produtoId = editandoId || crypto.randomUUID();\r\n        const storageRef = ref(storage, `produtos/${produtoId}/${Date.now()}_${arquivoImagem.name}`);\r\n        const snap = await uploadBytes(storageRef, arquivoImagem);\r\n        imagemUrl = await getDownloadURL(snap.ref);\r\n      }\r\n      const dados = { nome, sku, descricao, precoBase: parseFloat(precoBase) || 0, unidade, ativo, imagem: imagemUrl || '' };\r\n      if (editandoId) { await atualizarDocumento(COLECOES.PRODUTOS, editandoId, dados); }\r\n      else { await salvarDocumento(COLECOES.PRODUTOS, dados); }\r\n      limparForm(); setMostrarForm(false); carregar();\r\n    } catch (err) { console.error(err); alert('Erro ao salvar produto.'); }\r\n  };\r\n\r\n  const handleExcluir = async (id: string) => {\r\n    if (!window.confirm('Excluir produto?')) return;\r\n    try { await excluirDocumento(COLECOES.PRODUTOS, id); carregar(); } catch (err) { console.error(err); alert('Erro ao excluir produto.'); }\r\n  };\r\n\r\n  return (\r\n    <div>\r\n      <div className=\"mb-3\"><button className=\"btn\" style={{ background: '#ff530d', color: '#fff', borderRadius: '8px' }} onClick={() => { limparForm(); setMostrarForm(true); }}>+ Novo Produto</button></div>\r\n      {mostrarForm && (\r\n        <div className=\"card mb-4\" style={{ border: 'none', boxShadow: '0 2px 10px rgba(0,0,0,.06)', borderRadius: '12px' }}>\r\n          <div className=\"card-body\">\r\n            <h5 className=\"card-title mb-3\">{editandoId ? 'Editar Produto' : 'Novo Produto'}</h5>\r\n            <form onSubmit={handleSalvar}>\r\n              <div className=\"row g-3\">\r\n                <div className=\"col-md-4\"><label className=\"form-label\">Nome</label><input type=\"text\" className=\"form-control\" value={nome} onChange={(e) => setNome(e.target.value)} required /></div>\r\n                <div className=\"col-md-3\"><label className=\"form-label\">SKU</label><input type=\"text\" className=\"form-control\" value={sku} onChange={(e) => setSku(e.target.value)} /></div>\r\n                <div className=\"col-md-5\"><label className=\"form-label\">Descri├º├úo</label><input type=\"text\" className=\"form-control\" value={descricao} onChange={(e) => setDescricao(e.target.value)} /></div>\r\n                <div className=\"col-md-3\"><label className=\"form-label\">Pre├ºo Base (R$)</label><input type=\"number\" className=\"form-control\" value={precoBase} onChange={(e) => setPrecoBase(e.target.value)} min=\"0\" step=\"0.01\" required /></div>\r\n                <div className=\"col-md-2\"><label className=\"form-label\">Unidade</label><select className=\"form-select\" value={unidade} onChange={(e) => setUnidade(e.target.value)}><option value=\"un\">un</option><option value=\"m\">m</option><option value=\"kg\">kg</option><option value=\"cx\">cx</option></select></div>\r\n                <div className=\"col-md-3\"><label className=\"form-label\">Ativo</label><select className=\"form-select\" value={String(ativo)} onChange={(e) => setAtivo(e.target.value === 'true')}><option value=\"true\">Sim</option><option value=\"false\">N├úo</option></select></div>\r\n                <div className=\"col-md-4\"><label className=\"form-label\">Imagem</label><input type=\"file\" className=\"form-control\" accept=\"image/*\" onChange={(e) => setArquivoImagem(e.target.files?.[0] || null)} />{imagem && !arquivoImagem && <div className=\"mt-2\"><img src={imagem} alt=\"\" style={{ height: '60px', borderRadius: '6px', objectFit: 'cover' }} /><button type=\"button\" className=\"btn btn-sm btn-link text-danger p-0 ms-2\" onClick={() => setImagem('')}>Remover</button></div>}</div>\r\n                <div className=\"col-12 mt-2\"><button type=\"submit\" className=\"btn\" style={{ background: '#ff530d', color: '#fff' }}>Salvar</button><button type=\"button\" className=\"btn btn-outline-secondary ms-2\" onClick={() => { limparForm(); setMostrarForm(false); }}>Cancelar</button></div>\r\n              </div>\r\n            </form>\r\n          </div>\r\n        </div>\r\n      )}\r\n      {loading ? <div className=\"spinner-border text-primary\" role=\"status\" /> : (\r\n        <div style={{ background: '#fff', borderRadius: '12px', boxShadow: '0 2px 8px rgba(0,0,0,.06)', overflow: 'auto' }}>\r\n          <table className=\"table table-hover mb-0\">\r\n            <thead><tr style={{ background: '#1c1c1c', color: '#fff' }}><th>Nome</th><th>SKU</th><th>Descri├º├úo</th><th style={{ textAlign: 'right' }}>Pre├ºo</th><th>Un.</th><th>Ativo</th><th style={{ textAlign: 'right' }}>A├º├Áes</th></tr></thead>\r\n            <tbody>\r\n              {produtos.map((p) => <tr key={p.id}><td>{p.nome}</td><td><code>{p.sku}</code></td><td className=\"text-muted small\">{p.descricao}</td><td style={{ textAlign: 'right', fontWeight: 600 }}>R$ {p.precoBase.toLocaleString('pt-BR', { minimumFractionDigits: 2 })}</td><td>{p.unidade}</td><td><span className={`badge ${p.ativo ? 'bg-success' : 'bg-danger'}`} style={{ border: 'none', borderRadius: '8px' }}>{p.ativo ? 'SIM' : 'N├âO'}</span></td><td style={{ textAlign: 'right' }}><div className=\"d-flex justify-content-end gap-1\"><button className=\"btn btn-sm btn-outline-primary\" onClick={() => handleEditar(p)}>Editar</button><button className=\"btn btn-sm btn-outline-danger\" onClick={() => handleExcluir(p.id)}>Ô£ò</button></div></td></tr>)}\r\n              {produtos.length === 0 && <tr><td colSpan={7} className=\"text-center py-4 text-muted\">Nenhum produto cadastrado.</td></tr>}\r\n            </tbody>\r\n          </table>\r\n        </div>\r\n      )}\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\GABRIEL\\Documents\\GitHub\\or-amento\\cozinca-orcamentos\\src\\pages\\CriarOrcamento.tsx","messages":[{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\nC:\\Users\\GABRIEL\\Documents\\GitHub\\or-amento\\cozinca-orcamentos\\src\\pages\\CriarOrcamento.tsx:69:7\n  67 |   useEffect(() => {\n  68 |     if (buscaCliente.length < 2) {\n> 69 |       setClientesEncontrados([]);\n     |       ^^^^^^^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  70 |       return;\n  71 |     }\n  72 |     const timeout = setTimeout(async () => {","line":69,"column":7,"endLine":69,"endColumn":29},{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\nC:\\Users\\GABRIEL\\Documents\\GitHub\\or-amento\\cozinca-orcamentos\\src\\pages\\CriarOrcamento.tsx:85:7\n  83 |   useEffect(() => {\n  84 |     if (buscaProduto.length < 2) {\n> 85 |       setProdutosEncontrados([]);\n     |       ^^^^^^^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  86 |       return;\n  87 |     }\n  88 |     const timeout = setTimeout(async () => {","line":85,"column":7,"endLine":85,"endColumn":29},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'_i' is defined but never used.","line":297,"column":80,"messageId":"unusedVar","endLine":297,"endColumn":82}],"suppressedMessages":[],"errorCount":3,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect, useMemo, useCallback } from 'react';\r\nimport { useNavigate } from 'react-router-dom';\r\nimport { useAuth } from '../auth/useAuth';\r\nimport { buscarComFiltro, salvarDocumento, buscarColecao, COLECOES } from '../firebase/firestore';\r\nimport type { Cliente, Produto, ItemOrcamento, Orcamento } from '../types';\r\n\r\ntype ModalAba = 'buscar' | 'manual';\r\n\r\nfunction gerarCodigo(nome: string, totalExistente: number): string {\r\n  const numero = String(totalExistente + 1).padStart(3, '0');\r\n  const inicial = nome.charAt(0).toUpperCase();\r\n  return `${numero}${inicial}`;\r\n}\r\n\r\nexport default function CriarOrcamento() {\r\n  const { user } = useAuth();\r\n  const navigate = useNavigate();\r\n\r\n  const [nomeCliente, setNomeCliente] = useState('');\r\n  const [endereco, setEndereco] = useState('');\r\n  const [telefone, setTelefone] = useState('');\r\n  const [emailCliente, setEmailCliente] = useState('');\r\n  const [cnpj, setCnpj] = useState('');\r\n  const [clienteSelecionado, setClienteSelecionado] = useState<Cliente | null>(null);\r\n  const [buscaCliente, setBuscaCliente] = useState('');\r\n  const [clientesEncontrados, setClientesEncontrados] = useState<Cliente[]>([]);\r\n  const [vendedorNome, setVendedorNome] = useState(user?.nome || '');\r\n\r\n  const [itens, setItens] = useState<ItemOrcamento[]>([]);\r\n  const [setores, setSetores] = useState<string[]>([]);\r\n  const [novoSetor, setNovoSetor] = useState('');\r\n\r\n  const [modalAberto, setModalAberto] = useState(false);\r\n  const [abaModal, setAbaModal] = useState<ModalAba>('buscar');\r\n  const [buscaProduto, setBuscaProduto] = useState('');\r\n  const [produtosEncontrados, setProdutosEncontrados] = useState<Produto[]>([]);\r\n  const [itemSetor, setItemSetor] = useState('-');\r\n\r\n  const [manualNome, setManualNome] = useState('');\r\n  const [manualPreco, setManualPreco] = useState('');\r\n  const [manualDesc, setManualDesc] = useState('');\r\n\r\n  const [frete, setFrete] = useState('0');\r\n  const [desconto, setDesconto] = useState('0');\r\n  const [formaPagamento, setFormaPagamento] = useState('');\r\n  const [condicoesEntrega, setCondicoesEntrega] = useState('');\r\n  const [assinaturaVendedor, setAssinaturaVendedor] = useState('');\r\n\r\n  const [codigoOrcamento, setCodigoOrcamento] = useState('');\r\n  const [loading, setLoading] = useState(false);\r\n\r\n  useEffect(() => {\r\n    const carregarCodigo = async () => {\r\n      if (!user?.uid) return;\r\n      try {\r\n        const lista = await buscarColecao<Orcamento>(COLECOES.ORCAMENTOS);\r\n        const meusOrcamentos = lista.filter((o) => o.vendedorId === user.uid);\r\n        setCodigoOrcamento(gerarCodigo(user.nome || '', meusOrcamentos.length));\r\n        setVendedorNome(user.nome || '');\r\n      } catch {\r\n        // ignore\r\n      }\r\n    };\r\n    carregarCodigo();\r\n  }, [user]);\r\n\r\n  useEffect(() => {\r\n    if (buscaCliente.length < 2) {\r\n      setClientesEncontrados([]);\r\n      return;\r\n    }\r\n    const timeout = setTimeout(async () => {\r\n      const dados = await buscarComFiltro<Cliente>(\r\n        COLECOES.CLIENTES,\r\n        'nome',\r\n        buscaCliente\r\n      );\r\n      setClientesEncontrados(dados);\r\n    }, 250);\r\n    return () => clearTimeout(timeout);\r\n  }, [buscaCliente]);\r\n\r\n  useEffect(() => {\r\n    if (buscaProduto.length < 2) {\r\n      setProdutosEncontrados([]);\r\n      return;\r\n    }\r\n    const timeout = setTimeout(async () => {\r\n      const dados = await buscarComFiltro<Produto>(\r\n        COLECOES.PRODUTOS,\r\n        'nome',\r\n        buscaProduto\r\n      );\r\n      setProdutosEncontrados(dados);\r\n    }, 250);\r\n    return () => clearTimeout(timeout);\r\n  }, [buscaProduto]);\r\n\r\n  const adicionarSetor = useCallback(() => {\r\n    const nome = novoSetor.trim();\r\n    if (nome && !setores.includes(nome)) {\r\n      setSetores((prev) => [...prev, nome]);\r\n      setNovoSetor('');\r\n    }\r\n  }, [novoSetor, setores]);\r\n\r\n  const adicionarItem = useCallback(\r\n    (nome: string, descricao: string, preco: number, imagem?: string, produtoId?: string) => {\r\n      const novo: ItemOrcamento = {\r\n        produtoId,\r\n        nome,\r\n        descricao,\r\n        quantidade: 1,\r\n        precoUnitario: preco,\r\n        precoTotal: preco,\r\n        setor: itemSetor === '-' ? '' : itemSetor,\r\n        imagem,\r\n      };\r\n      setItens((prev) => [...prev, novo]);\r\n      setModalAberto(false);\r\n      setBuscaProduto('');\r\n      setManualNome('');\r\n      setManualPreco('');\r\n      setManualDesc('');\r\n      setAbaModal('buscar');\r\n    },\r\n    [itemSetor]\r\n  );\r\n\r\n  const atualizarQuantidade = useCallback((index: number, qtd: number) => {\r\n    setItens((prev) =>\r\n      prev.map((item, i) =>\r\n        i === index\r\n          ? { ...item, quantidade: Math.max(1, qtd), precoTotal: Math.max(1, qtd) * item.precoUnitario }\r\n          : item\r\n      )\r\n    );\r\n  }, []);\r\n\r\n  const removerItem = useCallback((index: number) => {\r\n    setItens((prev) => prev.filter((_, i) => i !== index));\r\n  }, []);\r\n\r\n  const totais = useMemo(() => {\r\n    const totalProdutos = itens.reduce((sum, i) => sum + i.precoTotal, 0);\r\n    const f = parseFloat(frete) || 0;\r\n    const d = parseFloat(desconto) || 0;\r\n    const totalGeral = totalProdutos + f;\r\n    const valorDesconto = totalGeral * (d / 100);\r\n    const totalFinal = totalGeral - valorDesconto;\r\n    return { totalProdutos, totalGeral, valorDesconto, totalFinal };\r\n  }, [itens, frete, desconto]);\r\n\r\n  const salvarOrcamento = async () => {\r\n    if (!user?.uid) return;\r\n    setLoading(true);\r\n    try {\r\n      const dados: Omit<Orcamento, 'id'> = {\r\n        codigo: codigoOrcamento,\r\n        vendedorId: user.uid,\r\n        vendedorNome: user.nome || '',\r\n        clienteId: clienteSelecionado?.id,\r\n        nomeCliente,\r\n        endereco,\r\n        telefone,\r\n        email: emailCliente,\r\n        cnpj,\r\n        itens,\r\n        frete: parseFloat(frete) || 0,\r\n        desconto: parseFloat(desconto) || 0,\r\n        totalProdutos: totais.totalProdutos,\r\n        totalGeral: totais.totalGeral,\r\n        valorDesconto: totais.valorDesconto,\r\n        totalFinal: totais.totalFinal,\r\n        formaPagamento,\r\n        condicoesEntrega,\r\n        assinaturaVendedor,\r\n        status: 'aberto',\r\n        criadoEm: new Date(),\r\n        atualizadoEm: new Date(),\r\n      };\r\n      await salvarDocumento(COLECOES.ORCAMENTOS, dados);\r\n      navigate('/orcamentos');\r\n    } catch (err) {\r\n      console.error('Erro ao salvar:', err);\r\n      alert('Erro ao salvar or├ºamento.');\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  };\r\n\r\n  return (\r\n    <div className=\"container my-4\">\r\n      <div className=\"d-flex align-items-center mb-3\">\r\n        <button onClick={() => navigate('/orcamentos')} className=\"btn btn-outline-secondary btn-sm me-3\">ÔåÉ Voltar</button>\r\n        <h2 style={{ color: '#ff530d', margin: 0 }}>Criar Novo Or├ºamento</h2>\r\n        <span className=\"badge ms-2\" style={{ background: '#fff3e8', color: '#8a3b12', border: '1px solid #ffd6b8', borderRadius: '8px' }}>{codigoOrcamento}</span>\r\n      </div>\r\n\r\n      {/* Dados do Cliente */}\r\n      <div className=\"card mb-3\" style={{ border: 'none', boxShadow: '0 2px 10px rgba(0,0,0,.06)', borderRadius: '12px' }}>\r\n        <div className=\"card-body\">\r\n          <h5 className=\"card-title mb-3\"><span className=\"badge me-2\" style={{ background: '#ff530d' }}>1</span>Dados do Cliente</h5>\r\n          <div className=\"row g-3\">\r\n            <div className=\"col-md-6\">\r\n              <label className=\"form-label\">Cliente (buscar cadastrado ou digite)</label>\r\n              <div style={{ position: 'relative' }}>\r\n                <input type=\"text\" className=\"form-control\" placeholder=\"Digite para buscar...\" value={buscaCliente} onChange={(e) => setBuscaCliente(e.target.value)} />\r\n                {clientesEncontrados.length > 0 && buscaCliente.length >= 2 && (\r\n                  <div className=\"card\" style={{ position: 'absolute', top: '100%', left: 0, right: 0, zIndex: 1000, maxHeight: '200px', overflowY: 'auto', boxShadow: '0 2px 10px rgba(0,0,0,.1)' }}>\r\n                    {clientesEncontrados.map((cli) => (\r\n                      <button key={cli.id} type=\"button\" className=\"list-group-item list-group-item-action\" onClick={() => {\r\n                        setClienteSelecionado(cli);\r\n                        setNomeCliente(cli.nome);\r\n                        setEndereco(cli.endereco);\r\n                        setTelefone(cli.telefone);\r\n                        setEmailCliente(cli.email);\r\n                        setCnpj(cli.documento);\r\n                        setBuscaCliente('');\r\n                        setClientesEncontrados([]);\r\n                      }}>{cli.nome}</button>\r\n                    ))}\r\n                  </div>\r\n                )}\r\n              </div>\r\n            </div>\r\n            <div className=\"col-md-6\">\r\n              <label className=\"form-label\">Nome do Cliente</label>\r\n              <input type=\"text\" className=\"form-control\" value={nomeCliente} onChange={(e) => setNomeCliente(e.target.value)} />\r\n            </div>\r\n            <div className=\"col-md-6\">\r\n              <label className=\"form-label\">Endere├ºo</label>\r\n              <input type=\"text\" className=\"form-control\" value={endereco} onChange={(e) => setEndereco(e.target.value)} />\r\n            </div>\r\n            <div className=\"col-md-3\">\r\n              <label className=\"form-label\">Telefone</label>\r\n              <input type=\"text\" className=\"form-control\" value={telefone} onChange={(e) => setTelefone(e.target.value)} />\r\n            </div>\r\n            <div className=\"col-md-3\">\r\n              <label className=\"form-label\">Email</label>\r\n              <input type=\"email\" className=\"form-control\" value={emailCliente} onChange={(e) => setEmailCliente(e.target.value)} />\r\n            </div>\r\n            <div className=\"col-md-4\">\r\n              <label className=\"form-label\">CNPJ / CPF</label>\r\n              <input type=\"text\" className=\"form-control\" value={cnpj} onChange={(e) => setCnpj(e.target.value)} />\r\n            </div>\r\n            <div className=\"col-md-4\">\r\n              <label className=\"form-label\">Vendedor</label>\r\n              <input type=\"text\" className=\"form-control\" value={vendedorNome} disabled />\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Produtos / Itens */}\r\n      <div className=\"card mb-3\" style={{ border: 'none', boxShadow: '0 2px 10px rgba(0,0,0,.06)', borderRadius: '12px' }}>\r\n        <div className=\"card-body\">\r\n          <h5 className=\"card-title mb-3\"><span className=\"badge me-2\" style={{ background: '#ff530d' }}>2</span>Produtos / Itens do Or├ºamento</h5>\r\n          <div className=\"d-flex align-items-center gap-2 mb-3 flex-wrap\">\r\n            <div style={{ minWidth: '200px' }}>\r\n              <label className=\"form-label mb-0\">Setor:</label>\r\n              <select className=\"form-select\" style={{ width: '200px' }} value={itemSetor} onChange={(e) => setItemSetor(e.target.value)}>\r\n                <option value=\"-\">ÔÇö Sem setor ÔÇö</option>\r\n                {setores.map((s) => <option key={s} value={s}>{s}</option>)}\r\n              </select>\r\n            </div>\r\n            <div className=\"d-flex gap-2\">\r\n              <input type=\"text\" className=\"form-control\" placeholder=\"Novo setor\" value={novoSetor} onChange={(e) => setNovoSetor(e.target.value)} style={{ width: '180px' }} />\r\n              <button type=\"button\" className=\"btn btn-outline-primary btn-sm\" onClick={adicionarSetor}>+ Adicionar Setor</button>\r\n              <button type=\"button\" className=\"btn\" style={{ background: '#ff530d', color: 'white', borderRadius: '8px' }} onClick={() => { setModalAberto(true); setAbaModal('buscar'); }}>+ Adicionar Produto</button>\r\n            </div>\r\n          </div>\r\n\r\n          {setores.map((setorNome) => {\r\n            const itensSetor = itens.filter((i) => i.setor === setorNome);\r\n            return (\r\n              <div key={setorNome} className=\"mb-2 border rounded overflow-hidden\">\r\n                <details>\r\n                  <summary className=\"btn btn-light w-100 text-start\" style={{ fontWeight: 700, cursor: 'pointer', padding: '10px 15px' }}>\r\n                    ÔûÂ {setorNome} <span className=\"badge bg-secondary\">{itensSetor.length} itens</span>\r\n                  </summary>\r\n                  <div className=\"p-2\">{itensSetor.map((item) => {\r\n                    const ri = itens.indexOf(item);\r\n                    return <RowItem key={ri} item={item} index={ri} onRemover={removerItem} onQtdChange={atualizarQuantidade} />;\r\n                  })}</div>\r\n                </details>\r\n              </div>\r\n            );\r\n          })}\r\n\r\n          {itens.filter((i) => !i.setor).length > 0 && (\r\n            <div className=\"mb-2 border rounded overflow-hidden\">\r\n              <details>\r\n                <summary className=\"btn btn-light w-100 text-start\" style={{ fontWeight: 700, cursor: 'pointer', padding: '10px 15px' }}>\r\n                  ÔûÂ Itens sem setor <span className=\"badge bg-secondary\">{itens.filter((i) => !i.setor).length} itens</span>\r\n                </summary>\r\n                <div className=\"p-2\">{itens.filter((i) => !i.setor).map((item, _i) => {\r\n                  const ri = itens.indexOf(item);\r\n                  return <RowItem key={ri} item={item} index={ri} onRemover={removerItem} onQtdChange={atualizarQuantidade} />;\r\n                })}</div>\r\n              </details>\r\n            </div>\r\n          )}\r\n\r\n          {itens.map((item, idx) => (\r\n            <RowItem key={idx} item={item} index={idx} onRemover={removerItem} onQtdChange={atualizarQuantidade} />\r\n          ))}\r\n\r\n          <div className=\"mt-4\">\r\n            <div className=\"list-group\" style={{ maxWidth: '350px', marginLeft: 'auto', borderRadius: '10px', overflow: 'hidden' }}>\r\n              <div className=\"list-group-item d-flex justify-content-between\"><span>Total Produtos</span><span style={{ fontWeight: 800 }}>R$ {totais.totalProdutos.toLocaleString('pt-BR', { minimumFractionDigits: 2 })}</span></div>\r\n              <div className=\"list-group-item d-flex justify-content-between\"><span>Frete</span><span style={{ fontWeight: 800 }}>R$ {(parseFloat(frete) || 0).toFixed(2)}</span></div>\r\n              <div className=\"list-group-item d-flex justify-content-between\"><span>Desconto (%)</span><input type=\"number\" className=\"form-control\" style={{ width: '80px', display: 'inline-block', textAlign: 'right' }} value={desconto} onChange={(e) => setDesconto(e.target.value)} min=\"0\" max=\"99\" /></div>\r\n              <div className=\"list-group-item d-flex justify-content-between\"><span>Valor Desconto</span><span style={{ fontWeight: 800, color: '#ff530d' }}>- R$ {totais.valorDesconto.toLocaleString('pt-BR', { minimumFractionDigits: 2 })}</span></div>\r\n              <div className=\"list-group-item d-flex justify-content-between\" style={{ background: '#fef6f2' }}><span style={{ fontWeight: 800, fontSize: '1.1rem' }}>Total Final</span><span style={{ fontWeight: 800, fontSize: '1.2rem', color: '#ff530d' }}>R$ {totais.totalFinal.toLocaleString('pt-BR', { minimumFractionDigits: 2 })}</span></div>\r\n            </div>\r\n            <div className=\"mt-2\">\r\n              <label className=\"form-label\">Frete</label>\r\n              <input type=\"number\" className=\"form-control\" style={{ maxWidth: '200px' }} value={frete} onChange={(e) => setFrete(e.target.value)} min=\"0\" step=\"0.01\" />\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Condi├º├Áes */}\r\n      <div className=\"card mb-4\" style={{ border: 'none', boxShadow: '0 2px 10px rgba(0,0,0,.06)', borderRadius: '12px' }}>\r\n        <div className=\"card-body\">\r\n          <h5 className=\"card-title mb-3\"><span className=\"badge me-2\" style={{ background: '#ff530d' }}>3</span>Condi├º├Áes do Or├ºamento</h5>\r\n          <div className=\"row g-3\">\r\n            <div className=\"col-md-6\">\r\n              <label className=\"form-label\">Forma de Pagamento</label>\r\n              <input type=\"text\" className=\"form-control\" value={formaPagamento} onChange={(e) => setFormaPagamento(e.target.value)} />\r\n            </div>\r\n            <div className=\"col-md-6\">\r\n              <label className=\"form-label\">Condi├º├Áes de Entrega</label>\r\n              <input type=\"text\" className=\"form-control\" value={condicoesEntrega} onChange={(e) => setCondicoesEntrega(e.target.value)} />\r\n            </div>\r\n            <div className=\"col-12\">\r\n              <label className=\"form-label\">Assinatura do Vendedor</label>\r\n              <input type=\"text\" className=\"form-control\" value={assinaturaVendedor} onChange={(e) => setAssinaturaVendedor(e.target.value)} />\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <div className=\"d-flex justify-content-end gap-2 mb-5\">\r\n        <button className=\"btn btn-outline-secondary\" onClick={() => navigate('/orcamentos')}>Cancelar</button>\r\n        <button className=\"btn\" disabled={loading} onClick={salvarOrcamento} style={{ background: '#ff530d', color: 'white', borderRadius: '8px', fontWeight: 600, padding: '10px 24px' }}>{loading ? 'Salvando...' : 'Salvar Or├ºamento'}</button>\r\n      </div>\r\n\r\n      {/* Modal Produto */}\r\n      {modalAberto && (\r\n        <div className=\"modal fade show\" style={{ display: 'block', backgroundColor: 'rgba(0,0,0,.5)', zIndex: 1060 }} onClick={() => setModalAberto(false)}>\r\n          <div className=\"modal-dialog modal-lg\" onClick={(e) => e.stopPropagation()}>\r\n            <div className=\"modal-content\" style={{ borderRadius: '12px' }}>\r\n              <div className=\"modal-header\">\r\n                <h5 className=\"modal-title\">Adicionar Produto</h5>\r\n                <button type=\"button\" className=\"btn-close\" onClick={() => setModalAberto(false)} />\r\n              </div>\r\n              <div className=\"modal-body\">\r\n                <div className=\"mb-3 d-flex gap-2\">\r\n                  <button type=\"button\" className={`btn btn-sm ${abaModal === 'buscar' ? 'btn-primary' : 'btn-outline-primary'}`} onClick={() => setAbaModal('buscar')}>Buscar Produto</button>\r\n                  <button type=\"button\" className={`btn btn-sm ${abaModal === 'manual' ? 'btn-primary' : 'btn-outline-primary'}`} onClick={() => setAbaModal('manual')}>Manual</button>\r\n                </div>\r\n                {abaModal === 'buscar' && (\r\n                  <div>\r\n                    <input type=\"text\" className=\"form-control mb-2\" placeholder=\"Buscar por nome...\" value={buscaProduto} onChange={(e) => setBuscaProduto(e.target.value)} />\r\n                    <div className=\"list-group\" style={{ maxHeight: '200px', overflowY: 'auto' }}>\r\n                      {produtosEncontrados.map((p) => (\r\n                        <button key={p.id} type=\"button\" className=\"list-group-item list-group-item-action\" onClick={() => adicionarItem(p.nome, p.descricao, p.precoBase, p.imagem, p.id)}>\r\n                          <div className=\"d-flex align-items-center gap-3\">\r\n                            {p.imagem && <img src={p.imagem} alt={p.nome} style={{ width: '44px', height: '44px', borderRadius: '6px', objectFit: 'cover' }} />}\r\n                            <div><strong>{p.nome}</strong><div className=\"small text-muted\">{p.descricao}</div></div>\r\n                            <span className=\"ms-auto fw-bold\" style={{ color: '#ff530d' }}>R$ {p.precoBase.toLocaleString('pt-BR', { minimumFractionDigits: 2 })}</span>\r\n                          </div>\r\n                        </button>\r\n                      ))}\r\n                    </div>\r\n                  </div>\r\n                )}\r\n                {abaModal === 'manual' && (\r\n                  <div>\r\n                    <div className=\"mb-3\"><label className=\"form-label\">Nome</label><input type=\"text\" className=\"form-control\" value={manualNome} onChange={(e) => setManualNome(e.target.value)} /></div>\r\n                    <div className=\"mb-3\"><label className=\"form-label\">Descri├º├úo</label><input type=\"text\" className=\"form-control\" value={manualDesc} onChange={(e) => setManualDesc(e.target.value)} /></div>\r\n                    <div className=\"mb-3\"><label className=\"form-label\">Pre├ºo Unit├írio</label><input type=\"number\" className=\"form-control\" value={manualPreco} onChange={(e) => setManualPreco(e.target.value)} min=\"0\" step=\"0.01\" /></div>\r\n                    <button type=\"button\" className=\"btn\" style={{ background: '#ff530d', color: '#fff' }} onClick={() => adicionarItem(manualNome || 'Item Manual', manualDesc, parseFloat(manualPreco) || 0)}>Adicionar</button>\r\n                  </div>\r\n                )}\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      )}\r\n    </div>\r\n  );\r\n}\r\n\r\nfunction RowItem({ item, index, onRemover, onQtdChange }: { item: ItemOrcamento; index: number; onRemover: (i: number) => void; onQtdChange: (i: number, qtd: number) => void }) {\r\n  return (\r\n    <div className=\"item-grid align-items-center py-2\" style={{ borderBottom: '1px solid #f0f0f0', fontSize: '0.9rem' }}>\r\n      <div className=\"d-flex align-items-center gap-2\">\r\n        {item.imagem && <img src={item.imagem} alt={item.nome} className=\"thumb\" />}\r\n        <span>{item.nome}</span>\r\n      </div>\r\n      <span className=\"text-muted small\">{item.descricao}</span>\r\n      <span><span className=\"badge\" style={{ background: '#fff3e8', color: '#8a3b12', border: '1px solid #ffd6b8' }}>{item.setor || 'ÔÇö'}</span></span>\r\n      <div><input type=\"number\" className=\"form-control form-control-sm\" style={{ width: '60px' }} value={item.quantidade} onChange={(e) => onQtdChange(index, parseInt(e.target.value) || 1)} min=\"1\" /></div>\r\n      <div style={{ textAlign: 'right' }}>R$ {item.precoUnitario.toLocaleString('pt-BR', { minimumFractionDigits: 2 })}</div>\r\n      <div className=\"subtotal\" style={{ textAlign: 'right', color: '#ff530d', fontWeight: 700 }}>R$ {item.precoTotal.toLocaleString('pt-BR', { minimumFractionDigits: 2 })}</div>\r\n      <div><button type=\"button\" className=\"btn btn-sm btn-outline-danger\" onClick={() => onRemover(index)}>Ô£ò</button></div>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\GABRIEL\\Documents\\GitHub\\or-amento\\cozinca-orcamentos\\src\\pages\\Dashboard.tsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"The 'primeiroDiaMes' object construction makes the dependencies of useMemo Hook (at line 50) change on every render. Move it inside the useMemo callback. Alternatively, wrap the initialization of 'primeiroDiaMes' in its own useMemo() Hook.","line":39,"column":9,"endLine":39,"endColumn":82},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"The 'ultimoDiaMes' object construction makes the dependencies of useMemo Hook (at line 50) change on every render. Move it inside the useMemo callback. Alternatively, wrap the initialization of 'ultimoDiaMes' in its own useMemo() Hook.","line":40,"column":9,"endLine":40,"endColumn":96},{"ruleId":"react-hooks/preserve-manual-memoization","severity":2,"message":"Compilation Skipped: Existing memoization could not be preserved\n\nReact Compiler has skipped optimizing this component because the existing manual memoization could not be preserved. This dependency may be mutated later, which could cause the value to change unexpectedly.\n\nC:\\Users\\GABRIEL\\Documents\\GitHub\\or-amento\\cozinca-orcamentos\\src\\pages\\Dashboard.tsx:50:19\n  48 |     const valor = filtrados.reduce((sum, o) => sum + (o.totalFinal || 0), 0);\n  49 |     return { qtd, valor };\n> 50 |   }, [orcamentos, primeiroDiaMes, ultimoDiaMes]);\n     |                   ^^^^^^^^^^^^^^ This dependency may be modified later\n  51 |\n  52 |   const dadosGrafico = useMemo(() => {\n  53 |     const ultimos6Meses: { mes: string; valor: number; qtd: number }[] = [];","line":50,"column":19,"endLine":50,"endColumn":33},{"ruleId":"react-hooks/preserve-manual-memoization","severity":2,"message":"Compilation Skipped: Existing memoization could not be preserved\n\nReact Compiler has skipped optimizing this component because the existing manual memoization could not be preserved. This dependency may be mutated later, which could cause the value to change unexpectedly.\n\nC:\\Users\\GABRIEL\\Documents\\GitHub\\or-amento\\cozinca-orcamentos\\src\\pages\\Dashboard.tsx:50:35\n  48 |     const valor = filtrados.reduce((sum, o) => sum + (o.totalFinal || 0), 0);\n  49 |     return { qtd, valor };\n> 50 |   }, [orcamentos, primeiroDiaMes, ultimoDiaMes]);\n     |                                   ^^^^^^^^^^^^ This dependency may be modified later\n  51 |\n  52 |   const dadosGrafico = useMemo(() => {\n  53 |     const ultimos6Meses: { mes: string; valor: number; qtd: number }[] = [];","line":50,"column":35,"endLine":50,"endColumn":47}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useEffect, useState, useMemo } from 'react';\r\nimport { useAuth } from '../auth/useAuth';\r\nimport { buscarColecao } from '../firebase/firestore';\r\nimport { COLECOES } from '../firebase/firestore';\r\nimport type { Orcamento } from '../types';\r\nimport {\r\n  LineChart,\r\n  Line,\r\n  BarChart,\r\n  Bar,\r\n  XAxis,\r\n  YAxis,\r\n  CartesianGrid,\r\n  Tooltip,\r\n  Legend,\r\n  ResponsiveContainer,\r\n} from 'recharts';\r\n\r\nexport default function Dashboard() {\r\n  const { user } = useAuth();\r\n  const [orcamentos, setOrcamentos] = useState<Orcamento[]>([]);\r\n  const [loading, setLoading] = useState(true);\r\n\r\n  useEffect(() => {\r\n    const carregarDados = async () => {\r\n      try {\r\n        const dados = await buscarColecao<Orcamento>(COLECOES.ORCAMENTOS);\r\n        setOrcamentos(dados);\r\n      } catch (err) {\r\n        console.error('Erro ao carregar dashboard:', err);\r\n      } finally {\r\n        setLoading(false);\r\n      }\r\n    };\r\n    carregarDados();\r\n  }, []);\r\n\r\n  const mesAtual = new Date();\r\n  const primeiroDiaMes = new Date(mesAtual.getFullYear(), mesAtual.getMonth(), 1);\r\n  const ultimoDiaMes = new Date(mesAtual.getFullYear(), mesAtual.getMonth() + 1, 0, 23, 59, 59);\r\n\r\n  const metricasMesAtual = useMemo(() => {\r\n    const filtrados = orcamentos.filter((o) => {\r\n      const data = o.criadoEm instanceof Date ? o.criadoEm : new Date(o.criadoEm);\r\n      return data >= primeiroDiaMes && data <= ultimoDiaMes;\r\n    });\r\n    const qtd = filtrados.length;\r\n    const valor = filtrados.reduce((sum, o) => sum + (o.totalFinal || 0), 0);\r\n    return { qtd, valor };\r\n  }, [orcamentos, primeiroDiaMes, ultimoDiaMes]);\r\n\r\n  const dadosGrafico = useMemo(() => {\r\n    const ultimos6Meses: { mes: string; valor: number; qtd: number }[] = [];\r\n    const agora = new Date();\r\n    for (let i = 5; i >= 0; i--) {\r\n      const data = new Date(agora.getFullYear(), agora.getMonth() - i, 1);\r\n      const mesFormatado = data.toLocaleDateString('pt-BR', { month: 'short', year: '2-digit' });\r\n      const primeiro = new Date(data.getFullYear(), data.getMonth(), 1);\r\n      const ultimo = new Date(data.getFullYear(), data.getMonth() + 1, 0, 23, 59, 59);\r\n      const itens = orcamentos.filter((o) => {\r\n        const d = o.criadoEm instanceof Date ? o.criadoEm : new Date(o.criadoEm);\r\n        return d >= primeiro && d <= ultimo;\r\n      });\r\n      ultimos6Meses.push({\r\n        mes: mesFormatado,\r\n        valor: itens.reduce((sum, o) => sum + (o.totalFinal || 0), 0),\r\n        qtd: itens.length,\r\n      });\r\n    }\r\n    return ultimos6Meses;\r\n  }, [orcamentos]);\r\n\r\n  if (loading) {\r\n    return (\r\n      <div className=\"d-flex justify-content-center align-items-center vh-100\">\r\n        <div className=\"spinner-border text-primary\" role=\"status\">\r\n          <span className=\"visually-hidden\">Carregando...</span>\r\n        </div>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  const mm = String(mesAtual.getMonth() + 1).padStart(2, '0');\r\n  const aaaa = mesAtual.getFullYear();\r\n\r\n  return (\r\n    <div>\r\n      <h2 className=\"mb-4\" style={{ color: '#1c1c1c', fontWeight: 700 }}>\r\n        Bem-vindo, {user?.nome}!\r\n      </h2>\r\n      <div className=\"text-center fw-bold mb-4\" style={{ color: '#ff530d' }}>\r\n        Resumo referente ao m├¬s: {mm}/{aaaa}\r\n      </div>\r\n\r\n      <div className=\"d-flex justify-content-around mb-5 flex-wrap gap-3\">\r\n        <div style={{ background: '#fff', borderRadius: '10px', boxShadow: '0 2px 6px rgba(0,0,0,0.1)', width: '100%', maxWidth: '400px', textAlign: 'center', padding: '20px' }}>\r\n          <h5 style={{ margin: 0, color: '#555' }}>Quantidade de Or├ºamentos (M├¬s Atual)</h5>\r\n          <p style={{ fontSize: '2rem', fontWeight: 800, marginTop: '10px', color: '#1c1c1c' }}>{metricasMesAtual.qtd}</p>\r\n        </div>\r\n        <div style={{ background: '#fff', borderRadius: '10px', boxShadow: '0 2px 6px rgba(0,0,0,0.1)', width: '100%', maxWidth: '400px', textAlign: 'center', padding: '20px' }}>\r\n          <h5 style={{ margin: 0, color: '#555' }}>Valor Total em Or├ºamentos (M├¬s Atual)</h5>\r\n          <p style={{ fontSize: '2rem', fontWeight: 800, marginTop: '10px', color: '#1c1c1c' }}>\r\n            R$ {metricasMesAtual.valor.toLocaleString('pt-BR', { minimumFractionDigits: 2 })}\r\n          </p>\r\n        </div>\r\n      </div>\r\n\r\n      <div style={{ background: '#fff', borderRadius: '10px', padding: '15px', marginBottom: '30px' }}>\r\n        <h5 style={{ color: '#1c1c1c', marginBottom: '15px' }}>Valor Total Mensal</h5>\r\n        <ResponsiveContainer width=\"100%\" height={300}>\r\n          <LineChart data={dadosGrafico}>\r\n            <CartesianGrid strokeDasharray=\"3 3\" />\r\n            <XAxis dataKey=\"mes\" />\r\n            <YAxis />\r\n            <Tooltip formatter={(value: number) => `R$ ${value.toFixed(2)}`} />\r\n            <Legend />\r\n            <Line type=\"monotone\" dataKey=\"valor\" name=\"Valor Total (R$)\" stroke=\"#ff530d\" strokeWidth={2} dot={{ fill: '#ff530d' }} activeDot={{ r: 6 }} />\r\n          </LineChart>\r\n        </ResponsiveContainer>\r\n      </div>\r\n\r\n      <div style={{ background: '#fff', borderRadius: '10px', padding: '15px' }}>\r\n        <h5 style={{ color: '#1c1c1c', marginBottom: '15px' }}>Quantidade de Or├ºamentos</h5>\r\n        <ResponsiveContainer width=\"100%\" height={300}>\r\n          <BarChart data={dadosGrafico}>\r\n            <CartesianGrid strokeDasharray=\"3 3\" />\r\n            <XAxis dataKey=\"mes\" />\r\n            <YAxis allowDecimals={false} />\r\n            <Tooltip />\r\n            <Legend />\r\n            <Bar dataKey=\"qtd\" name=\"Quantidade\" fill=\"#1c1c1c\" radius={[4, 4, 0, 0]} />\r\n          </BarChart>\r\n        </ResponsiveContainer>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\GABRIEL\\Documents\\GitHub\\or-amento\\cozinca-orcamentos\\src\\pages\\EditarOrcamento.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\GABRIEL\\Documents\\GitHub\\or-amento\\cozinca-orcamentos\\src\\pages\\ListarOrcamentos.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\GABRIEL\\Documents\\GitHub\\or-amento\\cozinca-orcamentos\\src\\pages\\Login.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\GABRIEL